{
    "go.delveConfig": {
        "dlvToolPath": "dlv",
        "apiVersion": 2,
        "showLog": true
    },
    "go.toolsEnvVars": {
        "GOPROXY": "https://goproxy.cn,direct"
    },
    "go.lintOnSave": "off",
    "[go]": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    "go.buildFlags": ["-gcflags=all=-N -l"],
    "go.testFlags": ["-v"]
}
